# IoTAPS frontend environment (EXAMPLE). Copy to `.env` for local dev.
# All Vite-exposed vars must be prefixed with VITE_.

# REST API base path. In production the SPA is served by Nginx which proxies
# /api to FastAPI, so the relative default works. Override for split hosting.
VITE_API_BASE_URL=/api/v1

# Dev-server proxy targets (used only by `vite dev`, see vite.config.js).
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_WS_PROXY_TARGET=ws://localhost:8000

# Google OAuth client id for Google Identity Services sign-in (Req 1.2).
# Leave blank to hide/disable the Google sign-in button in local dev.
VITE_GOOGLE_CLIENT_ID=
