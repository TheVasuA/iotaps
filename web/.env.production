# Production env vars (used by Vite at build time for Cloudflare Pages deploy).
# API calls go directly to the VPS via api.iotaps.com (Cloudflare _redirects
# proxy only supports GET on free plan, so we bypass it entirely).
VITE_API_BASE_URL=https://api.iotaps.com/api/v1

# WebSocket connects directly to the VPS (not through Cloudflare Pages).
VITE_WS_URL=wss://api.iotaps.com/ws

# Google OAuth (set via Cloudflare Pages dashboard env vars in production)
# VITE_GOOGLE_CLIENT_ID=your-production-client-id
