# IoTAPS Platform environment configuration (EXAMPLE)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# No real secrets belong in this example file.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=false
API_WORKERS=4
# Number of Uvicorn workers for the dedicated WebSocket service.
# Each async worker can handle 2000+ concurrent WS connections.
WS_WORKERS=2
# Public base URL of the platform (used for links, webhooks, public dashboards)
PUBLIC_BASE_URL=https://iotaps.example.com
# Comma-separated list of allowed CORS origins ("*" allows all)
CORS_ALLOW_ORIGINS=*
# TTL (seconds) for the read-through Redis cache of platform_settings
PLATFORM_SETTINGS_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# PostgreSQL + TimescaleDB (Relational_DB + Time_Series_DB)
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=iotaps
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=iotaps
# SQLAlchemy/async connection URL (derived from the values above)
DATABASE_URL=postgresql+asyncpg://iotaps:change_me_postgres@postgres:5432/iotaps

POSTGRES_HOST=localhost
REDIS_HOST=localhost



# ---------------------------------------------------------------------------
# Redis (Cache_Store: cache, pub/sub, queue, sessions, quota counters)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis
REDIS_URL=redis://:change_me_redis@redis:6379/0

# ---------------------------------------------------------------------------
# MQTT (Mosquitto broker)
# ---------------------------------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_WS_PORT=9001
# Internal credentials used by backend workers (MQTT_Listener, etc.)
MQTT_USERNAME=iotaps_backend
MQTT_PASSWORD=change_me_mqtt
# Topic root: iotaps/{org_id}/{device_id}/{type}
MQTT_TOPIC_ROOT=iotaps
# Shared secret the mosquitto-go-auth HTTP backend sends to the FastAPI auth
# endpoints (/api/v1/mqtt/auth/*) so the broker's auth calls are trusted.
MQTT_AUTH_HTTP_SECRET=change_me_mqtt_auth_secret
# "superuser" username that bypasses per-org ACLs (used by backend workers that
# must subscribe across all orgs, e.g. MQTT_Listener). Matches MQTT_USERNAME.
MQTT_SUPERUSER=iotaps_backend

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_use_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
# Google OAuth (Req 1.2)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Razorpay (Payment_Gateway: payments, payouts, commission split)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# RazorpayX (partner payouts)
RAZORPAYX_ACCOUNT_NUMBER=

# ---------------------------------------------------------------------------
# Firebase (push notifications - Req 20.5)
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Path to the service-account JSON mounted into the container
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-service-account.json

# ---------------------------------------------------------------------------
# Telegram (notifications - Req 20.1)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Email (notifications / reports)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@iotaps.com
