# IoTAPS Platform environment configuration (EXAMPLE)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# No real secrets belong in this example file.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=false
API_WORKERS=4
# Number of Uvicorn workers for the dedicated WebSocket service.
# Each async worker can handle 2000+ concurrent WS connections.
WS_WORKERS=2
# Public base URL of the platform (used for links, webhooks, public dashboards)
PUBLIC_BASE_URL=https://iotaps.example.com
# Comma-separated list of allowed CORS origins ("*" allows all)
CORS_ALLOW_ORIGINS=*
# TTL (seconds) for the read-through Redis cache of platform_settings
PLATFORM_SETTINGS_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# PostgreSQL + TimescaleDB (Relational_DB + Time_Series_DB)
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=iotaps
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=iotaps
# SQLAlchemy/async connection URL (derived from the values above)
DATABASE_URL=postgresql+asyncpg://iotaps:change_me_postgres@postgres:5432/iotaps

POSTGRES_HOST=localhost
REDIS_HOST=localhost



# ---------------------------------------------------------------------------
# Redis (Cache_Store: cache, pub/sub, queue, sessions, quota counters)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis
REDIS_URL=redis://:change_me_redis@redis:6379/0

# ---------------------------------------------------------------------------
# MQTT (Mosquitto broker)
# ---------------------------------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_WS_PORT=9001
# Internal credentials used by backend workers (MQTT_Listener, etc.)
MQTT_USERNAME=iotaps_backend
MQTT_PASSWORD=change_me_mqtt
# Topic root: iotaps/{org_id}/{device_id}/{type}
MQTT_TOPIC_ROOT=iotaps
# Shared secret the mosquitto-go-auth HTTP backend sends to the FastAPI auth
# endpoints (/api/v1/mqtt/auth/*) so the broker's auth calls are trusted.
MQTT_AUTH_HTTP_SECRET=change_me_mqtt_auth_secret
# "superuser" username that bypasses per-org ACLs (used by backend workers that
# must subscribe across all orgs, e.g. MQTT_Listener). Matches MQTT_USERNAME.
MQTT_SUPERUSER=iotaps_backend

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_use_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
# Google OAuth (Req 1.2)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Super Admin auto-seed (created on startup if not exists)
# ---------------------------------------------------------------------------
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change_me_strong_password

# ---------------------------------------------------------------------------
# Razorpay (Payment_Gateway: payments, payouts, commission split)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# RazorpayX (partner payouts)
RAZORPAYX_ACCOUNT_NUMBER=

# ---------------------------------------------------------------------------
# Firebase (push notifications - Req 20.5)
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Path to the service-account JSON mounted into the container
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-service-account.json

# ---------------------------------------------------------------------------
# Telegram (notifications - Req 20.1)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Email (notifications / reports)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@iotaps.com

# ---------------------------------------------------------------------------
# Off-site backups (Cloudflare R2 / S3) — used by infra/scripts/backup-to-r2.sh
# ---------------------------------------------------------------------------
# Cloudflare R2 bucket for nightly database dumps (or any S3-compatible store).
BACKUP_R2_BUCKET=iotaps-backups
# S3 endpoint: https://<accountid>.r2.cloudflarestorage.com
BACKUP_R2_ENDPOINT=
BACKUP_R2_ACCESS_KEY_ID=
BACKUP_R2_SECRET_ACCESS_KEY=
# Days to keep dumps locally AND in the bucket (default 14).
BACKUP_RETENTION_DAYS=14
# Where dumps are written on the VPS before upload (default <repo>/backups).
BACKUP_LOCAL_DIR=/projects/iotaps/backups
# Container names (override only if you renamed them).
BACKUP_POSTGRES_CONTAINER=iotaps-postgres
API_CONTAINER=iotaps-api
# Optional dead-man's switch: a URL pinged after each successful backup
# (e.g. https://hc-ping.com/<uuid> from healthchecks.io). Alerts if a run fails.
BACKUP_HEALTHCHECK_URL=

# ---------------------------------------------------------------------------
# Standby failover (optional) — used by infra/scripts/promote-standby.sh
# ---------------------------------------------------------------------------
# Cloudflare API token with Zone:DNS:Edit on the iotaps zone, used to repoint
# the api/mqtt A-records to the standby server during promotion.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Comma-separated A-records to repoint to the standby on failover.
FAILOVER_DNS_RECORDS=api.iotaps.com,mqtt.iotaps.com
# Standby public IP (auto-detected via api.ipify.org if left blank).
FAILOVER_PUBLIC_IP=

# ---------------------------------------------------------------------------
# MongoDB identity vault (off-VPS mirror of critical identity data)
# ---------------------------------------------------------------------------
# A free MongoDB Atlas 512MB cluster is ample for identity-only data. Leave
# MONGODB_URI empty to disable (the vault worker idles, all calls are no-ops).
# Mirrors users (email/role/password HASH), device credentials (id/token/ACL),
# and devices — never plaintext passwords. Postgres stays the source of truth.
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=iotaps_vault
# Seconds between full identity re-syncs by the vault worker.
MONGODB_SYNC_INTERVAL_SECONDS=900
